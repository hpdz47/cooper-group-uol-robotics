$$ REL	"D11=D[11]"
$$ INV_REL	"D[11]=D11"
$$ UNIT	"sec"
$$ FORMAT	"%14.8f sec"
$$ TEXT	" "
$$ END
$$ T_NAME		D12
$$ TYPE	R32
$$ CLASS	ACQU
$$ SUBRANGE 0.0 1e38
$$ REL	"D12=D[12]"
$$ INV_REL	"D[12]=D12"
$$ UNIT	"sec"
$$ FORMAT	"%14.8f sec"
$$ TEXT	" "
$$ END
$$ T_NAME		D16
