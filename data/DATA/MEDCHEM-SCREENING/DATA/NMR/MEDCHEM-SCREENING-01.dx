$$ CLASS	ACQU
$$ SUBRANGE 0.0 1e38
$$ REL	"D16=D[16]"
$$ INV_REL	"D[16]=D16"
$$ UNIT	"sec"
$$ FORMAT	"%14.8f sec"
$$ TEXT	" "
$$ END
$$ T_NAME		L6
$$ TYPE	R32
$$ CLASS	ACQU
$$ SUBRANGE 0.0 1e38
$$ REL	"L6=L[6]"
$$ INV_REL	"L[6]=L6"
$$ FORMAT	"%14.0f"
$$ TEXT	" "
$$ END
$$ T_NAME		L7
$$ TYPE	R32
$$ CLASS	ACQU
$$ SUBRANGE 0.0 1e38
$$ REL	"L7=L[7]"
$$ INV_REL	"L[7]=L7"
$$ FORMAT	"%14.0f"
$$ TEXT	" "
$$ END
$$ NAME		TD0
$$ TEXT	" "
$$ END
$$ NAME		ZGOPTNS
$$ TEXT	" "
$$ END
