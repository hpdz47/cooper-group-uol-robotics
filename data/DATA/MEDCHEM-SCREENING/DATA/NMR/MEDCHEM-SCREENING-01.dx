$$ INV_REL	"P[19]=P19"
$$ UNIT	"usec"
$$ FORMAT	"%14.2f usec"
$$ TEXT	" "
$$ END
$$ T_NAME		PLW1
$$ TYPE	R32
$$ CLASS	ACQU
$$ REL	"PLW1=PLW[1]"
$$ INV_REL	"PLW[1]=PLW1"
$$ UNIT	"W"
$$ FORMAT	"%14.8f W"
$$ TEXT	"power PLW1 "
$$ END
