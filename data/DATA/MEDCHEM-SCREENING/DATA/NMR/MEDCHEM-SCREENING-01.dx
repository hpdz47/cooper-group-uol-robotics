$$ FORMAT	"%14.7f MHz"
$$ TEXT	" "
$$ END
$$ NAME		NUC1
$$ NONEDIT
$$ TEXT	" "
$$ END
$$ T_NAME		P1
$$ TYPE	R32
$$ CLASS	ACQU
$$ SUBRANGE 0.0 1.0e10
$$ REL	"P1=P[1]"
$$ INV_REL	"P[1]=P1"
$$ UNIT	"usec"
$$ FORMAT	"%14.2f usec"
$$ TEXT	" "
$$ END
$$ T_NAME		P18
$$ TYPE	R32
$$ CLASS	ACQU
$$ SUBRANGE 0.0 1.0e10
